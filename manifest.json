{
  "name": "SplunkAlarmExtensions",
  "version": "1.0.0",
  "manifest_version": 3,
  "description": "Chrome extension that monitors Splunk DOM values and triggers alarms.",
  "permissions": [
    "scripting",
    "tabs",
    "activeTab",
    "storage",
    "system.display"
  ],
  "host_permissions": [
    "Replace with any domain"
  ],
  "action": {
    "default_title": "Inject / Toggle SplunkAlarm UI"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "UI_Panel.html",
        "UI_Panel.js",
        "AlarmSound.wav",
        "SettingWindow.html",
        "SettingWindow.js"
      ],
      "matches": [
        "Replace with any domain"
      ]
    }
  ]
}